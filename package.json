{
  "name": "breakeven",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Rent-vs-buy calculator with live data and a year-by-year breakdown of the math.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && vite-node scripts/gen-og-pages.tsx",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "fetch-data": "node scripts/fetch-data.mjs",
    "fetch-zips": "node scripts/fetch-zips.mjs",
    "validate-data": "node scripts/validate-data.mjs",
    "render-zip-og": "vite-node scripts/render-zip-og.tsx",
    "typecheck": "tsc -b --noEmit --force"
  },
  "dependencies": {
    "@vercel/blob": "^2.4.0",
    "@vercel/og": "^0.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.19.21",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
